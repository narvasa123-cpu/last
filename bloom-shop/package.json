{
  "name": "bloom-shop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "seed:users": "node ./scripts/seed-users.mjs",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name bloom-shop-production",
    "deploy:cloudflare:preview": "npm run build && npx wrangler pages deploy dist --project-name bloom-shop-production --branch preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.100.5",
    "chart.js": "^4.4.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
